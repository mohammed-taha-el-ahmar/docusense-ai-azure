# Azure core
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP=rg-docusense-dev
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://aoai-docusense-dev.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://srch-docusense-dev.search.windows.net
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=docusense-clauses

# Azure ML
AML_WORKSPACE_NAME=aml-docusense-dev
AML_ENDPOINT_NAME=docusense-online

# Storage
STORAGE_ACCOUNT=stdocusensedev
STORAGE_CONTAINER_RAW=raw
STORAGE_CONTAINER_EVALS=evals
STORAGE_CONTAINER_TRACES=traces

# Content safety
CONTENT_SAFETY_ENDPOINT=https://cs-docusense-dev.cognitiveservices.azure.com
CONTENT_SAFETY_KEY=

# Monitoring
APPINSIGHTS_CONNECTION_STRING=

# Runtime
DOCUSENSE_ENV=local
CLASSIFIER_CONFIDENCE_THRESHOLD=0.75
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=15
LLM_MAX_RETRIES=3
